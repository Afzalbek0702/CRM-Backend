generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
  CASHIER
  MANAGER
  WORKER
  CEO
  SUPERADMIN
}

enum Status {
  ACTIVE
  ARCHIVED
  DELETED
  FINISHED
  CONVERTED
  NEW
}
enum SalaryType {
  CASH
  BANK_TRANSFER
  OTHER
}
enum StudentStatus {
  ACTIVE
  INACTIVE
  FROZEN
  DEBTOR
  GRADUATED
  ARCHIVED
  DELETED
}

model attendance {
  id          Int       @id @default(autoincrement())
  tenant_id   String
  group_id    Int?
  student_id  Int?
  lesson_date DateTime  @db.Date
  status      Boolean
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  groups      groups?   @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students    students? @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([group_id, student_id, lesson_date])
}

model courses {
  id           Int       @id @default(autoincrement())
  tenant_id   String
  name         String
  price        Int
  lesson_count Int?
  status       Status   @default(ACTIVE)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

model enrollments {
  id          Int       @id @default(autoincrement())
  tenant_id   String
  student_id  Int?
  group_id    Int?
  joined_at   DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  status      Status   @default(ACTIVE)
  end_date    DateTime? @db.Date
  archived_at DateTime? @db.Timestamp(6)
  groups      groups?   @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students    students? @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  next_billing_date DateTime?     @db.Date

//   @@unique([student_id, group_id, status])
  @@index([student_id, status, next_billing_date])
  @@index([next_billing_date, status]) // Cron query uchun kritik
}

model expenses {
  id           Int       @id @default(autoincrement())
  tenant_id   String
  amount       Decimal   @db.Decimal(12, 2)
  description  String?
  method       String?   @db.VarChar(10)
  expense_date DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_by   Int?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  status       Status   @default(ACTIVE)
  users        users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model groups {
  id          Int           @id @default(autoincrement())
  tenant_id   String
  name        String        @db.VarChar(100)
  course_type String?       @db.VarChar(100)
  price       Int
  lesson_time String?       @db.VarChar(50)
  lesson_days String[]
  teacher_id  Int?
  status      Status   @default(ACTIVE)
  created_at  DateTime?     @default(now()) @db.Timestamp(6)
  room_id     Int?
  attendance  attendance[]
  enrollments enrollments[]
  rooms       rooms?        @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teachers    teachers?     @relation(fields: [teacher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments    payments[]
}

model leads {
  id                Int       @id @default(autoincrement())
  tenant_id         String
  full_name         String
  phone             String
  source            String?
  interested_course String?
  status            Status    @default(NEW)
  comment           String?
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @db.Timestamp(6)
}

model payments {
  id         Int       @id @default(autoincrement())
  tenant_id   String
  student_id Int?
  group_id   Int?
  amount     Int
  paid_at    DateTime? @default(now()) @db.Timestamp(6)
  method     String?   @db.VarChar(10)
  paid_month DateTime? @db.Date
  status     Status    @default(ACTIVE)
  deleted_at DateTime? @db.Timestamp(6)
  groups     groups?   @relation(fields: [group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students   students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenant_id, student_id, paid_month, paid_at, status])
}

model rooms {
  id       Int      @id @default(autoincrement())
  tenant_id   String
  name     String
  capacity Int?
  status   Status   @default(ACTIVE)
  groups   groups[]
}

model salary {
  id          Int       @id @default(autoincrement())
  tenant_id   String
  worker_id   Int       // Worker bilan bog'lanish
  worker      workers   @relation(fields: [worker_id], references: [id], onDelete: Cascade)
  month       String?   @db.VarChar(7) 
  amount      Decimal   @db.Decimal(12, 2)
  method      String?   @db.VarChar(10)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  status      Status   @default(ACTIVE)
}

model students {
  id            Int           @id @default(autoincrement())
  tenant_id     String
  full_name     String        @db.VarChar(255)
  phone         String?       @db.VarChar(20)
  status        StudentStatus @default(ACTIVE)
  balance       Decimal       @default(0) @db.Decimal(12, 2)
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  birthday      DateTime?     @db.Date
  parents_name  String?       @db.VarChar(50)
  deleted_at    DateTime?     @db.Timestamp(6)
  parents_phone String?       @db.VarChar(20)
  last_billed_at DateTime?
  attendance    attendance[]
  enrollments   enrollments[]
  payments      payments[]

  @@index([tenant_id, status])
  @@index([tenant_id, balance, status]) // Qarzdorlarni tez qidirish
}

model teachers {
  id         Int      @id @default(autoincrement())
  tenant_id   String
  workerId   Int      @unique
  worker     workers  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  full_name  String   @db.VarChar(255)
  phone      String?  @db.VarChar(20)
  created_at DateTime @default(now())
  status     Status   @default(ACTIVE)
  groups     groups[]
  @@map("teachers")
}

model users {
  id            Int       @id @default(autoincrement())
  phone         String    @unique @db.VarChar(20)
  password_hash String
  role          UserRole  @default(WORKER)
  created_at    DateTime  @default(now())
  status        Status    @default(ACTIVE)
  
  worker        workers?
  expenses      expenses[]
  tenant_id     String   @db.Uuid
  tenant        tenants? @relation(fields: [tenant_id], references: [id])
  @@map("users")
}

model workers {
  id          Int       @id @default(autoincrement())
  user_id     Int       @unique
  user        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenant_id   String
  full_name   String    @db.VarChar(100)
  phone       String?   @db.VarChar(20)
  position    String    @db.VarChar(50) @default("Xodim")
  salary      Decimal?  @db.Decimal(10, 2)
  salary_type String?   @db.VarChar(20) @default("CASH")
  birthday    DateTime? @db.Date
  img         String?
  status      Status    @default(ACTIVE)
  hired_at    DateTime  @default(now())
  created_at  DateTime  @default(now())
  
  teacher     teachers?
  salaries    salary[]  // Worker uchun barcha ish haqi yozuvlari
  @@map("workers")
}

model tenants {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @db.VarChar(100)
  subdomain  String    @unique @db.VarChar(50)
  created_at DateTime  @default(now())

  users      users[]
}